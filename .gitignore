# =============================================================================
# OpenTofu Git Ignore
# =============================================================================

# Local .opentofu directories
**/.terraform/*

# .tfstate files (OpenTofu uses same file format)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
!terraform.tfvars.example

# Ignore override files as they are usually used for local dev
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.opentofurc
opentofu.rc
.terraformrc
terraform.rc

# Ignore lock files (optional - you might want to commit these)
# .opentofu.lock.hcl
**/.terraform.lock.hcl

# Plan files
*.tfplan

# Backend config files (may contain sensitive data)
*.tfbackend

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
